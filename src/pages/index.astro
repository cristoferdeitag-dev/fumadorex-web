---
// Fumadorex — Landing Page Oficial
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Deja de fumar sin fuerza de voluntad | Fumadorex</title>
    <meta name="description" content="Fumadorex: método psicológico con 96% de efectividad para dejar de fumar. Sin parches, sin medicamentos. Humanismo y Conductismo. Desde $6,999 MXN." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <style>
      *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
      :root {
        --azul: #1B3A6B;
        --azul-claro: #2353A0;
        --dorado: #F4A914;
        --texto: #1a1a1a;
        --gris: #f5f5f5;
        --gris-texto: #555;
      }
      body { font-family: 'Inter', sans-serif; color: var(--texto); background: #fff; }
      a { text-decoration: none; }

      /* NAV */
      nav {
        background: var(--azul);
        padding: 16px 24px;
        display: flex;
        align-items: center;
        justify-content: space-between;
      }
      .nav-logo { color: white; font-weight: 900; font-size: 1.3rem; letter-spacing: -0.5px; }
      .nav-logo span { color: var(--dorado); }
      .nav-cta {
        background: var(--dorado);
        color: #111;
        font-weight: 700;
        font-size: 0.85rem;
        padding: 10px 20px;
        border-radius: 6px;
      }

      /* HERO */
      .hero {
        background: linear-gradient(135deg, var(--azul) 0%, #0d2347 100%);
        color: white;
        padding: 80px 24px 72px;
        text-align: center;
      }
      .hero-badge {
        display: inline-block;
        background: rgba(244,169,20,0.2);
        border: 1px solid rgba(244,169,20,0.5);
        color: var(--dorado);
        padding: 6px 18px;
        border-radius: 999px;
        font-size: 0.8rem;
        font-weight: 600;
        letter-spacing: 0.05em;
        margin-bottom: 24px;
        text-transform: uppercase;
      }
      .hero h1 {
        font-size: clamp(2rem, 5vw, 3.6rem);
        font-weight: 900;
        line-height: 1.15;
        max-width: 800px;
        margin: 0 auto 20px;
      }
      .hero h1 em { color: var(--dorado); font-style: normal; }
      .hero p {
        font-size: 1.1rem;
        opacity: 0.85;
        max-width: 580px;
        margin: 0 auto 36px;
        line-height: 1.7;
      }
      .btn-hero {
        display: inline-block;
        background: var(--dorado);
        color: #111;
        font-weight: 800;
        font-size: 1.05rem;
        padding: 18px 40px;
        border-radius: 8px;
        transition: transform 0.2s, box-shadow 0.2s;
        box-shadow: 0 4px 20px rgba(244,169,20,0.4);
      }
      .btn-hero:hover { transform: translateY(-2px); box-shadow: 0 8px 28px rgba(244,169,20,0.5); }
      .hero-sub { margin-top: 20px; font-size: 0.85rem; opacity: 0.6; }

      /* STATS */
      .stats {
        background: white;
        border-bottom: 1px solid #eee;
        padding: 48px 24px;
        display: flex;
        justify-content: center;
        gap: 64px;
        flex-wrap: wrap;
        text-align: center;
      }
      .stat-num { font-size: 2.8rem; font-weight: 900; color: var(--azul); line-height: 1; }
      .stat-label { font-size: 0.9rem; color: var(--gris-texto); margin-top: 6px; }

      /* SECCIÓN GENÉRICA */
      .section { padding: 80px 24px; }
      .section-inner { max-width: 960px; margin: 0 auto; }
      .section-tag {
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--dorado);
        margin-bottom: 12px;
      }
      h2 { font-size: clamp(1.7rem, 3vw, 2.5rem); font-weight: 800; line-height: 1.2; }
      h2 span { color: var(--azul); }
      .section-lead { color: var(--gris-texto); line-height: 1.7; font-size: 1rem; max-width: 640px; margin-top: 12px; }

      /* METODOLOGÍA CARDS */
      .metodo-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 24px;
        margin-top: 48px;
      }
      .metodo-card {
        background: var(--gris);
        border-radius: 12px;
        padding: 32px 28px;
        border-top: 4px solid var(--dorado);
      }
      .metodo-icon { font-size: 2rem; margin-bottom: 16px; }
      .metodo-card h3 { font-size: 1.05rem; font-weight: 700; margin-bottom: 10px; color: var(--azul); }
      .metodo-card p { font-size: 0.9rem; color: var(--gris-texto); line-height: 1.65; }

      /* TESTIMONIOS */
      .testimonios-bg { background: var(--gris); }
      .testimonios-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 24px;
        margin-top: 48px;
      }
      .testimonio {
        background: white;
        border-radius: 12px;
        padding: 28px 24px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.06);
      }
      .testimonio-stars { color: var(--dorado); font-size: 0.95rem; margin-bottom: 12px; }
      .testimonio p { font-size: 0.9rem; color: var(--gris-texto); line-height: 1.65; font-style: italic; }
      .testimonio-autor { margin-top: 16px; font-weight: 700; font-size: 0.9rem; color: var(--azul); }
      .testimonio-detalle { font-size: 0.8rem; color: #999; }

      /* PRECIOS */
      .precios-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
        gap: 24px;
        margin-top: 48px;
        align-items: start;
      }
      .precio-card {
        border: 2px solid #e5e5e5;
        border-radius: 16px;
        padding: 36px 28px;
        text-align: center;
        position: relative;
      }
      .precio-card.destacado {
        border-color: var(--dorado);
        box-shadow: 0 8px 32px rgba(244,169,20,0.15);
      }
      .precio-badge-top {
        position: absolute;
        top: -14px;
        left: 50%;
        transform: translateX(-50%);
        background: var(--dorado);
        color: #111;
        font-weight: 700;
        font-size: 0.75rem;
        padding: 4px 16px;
        border-radius: 999px;
        white-space: nowrap;
      }
      .precio-fecha { font-size: 0.8rem; color: #999; margin-bottom: 8px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; }
      .precio-num { font-size: 2.4rem; font-weight: 900; color: var(--azul); line-height: 1; }
      .precio-moneda { font-size: 1rem; font-weight: 600; vertical-align: super; }
      .precio-msi { font-size: 0.8rem; color: #888; margin: 4px 0 20px; }
      .precio-lista { list-style: none; text-align: left; margin-bottom: 28px; }
      .precio-lista li { font-size: 0.88rem; color: var(--gris-texto); padding: 7px 0; border-bottom: 1px solid #f0f0f0; }
      .precio-lista li::before { content: "✓ "; color: var(--dorado); font-weight: 700; }
      .btn-precio {
        display: block;
        background: var(--azul);
        color: white;
        font-weight: 700;
        font-size: 0.9rem;
        padding: 14px;
        border-radius: 8px;
        text-align: center;
      }
      .precio-card.destacado .btn-precio { background: var(--dorado); color: #111; }

      /* FAQ */
      .faq-lista { margin-top: 40px; max-width: 720px; }
      .faq-item { border-bottom: 1px solid #eee; padding: 24px 0; }
      .faq-item h3 { font-size: 1rem; font-weight: 700; color: var(--azul); margin-bottom: 10px; }
      .faq-item p { font-size: 0.92rem; color: var(--gris-texto); line-height: 1.65; }

      /* HISTORIA */
      .historia-grid {
        display: grid;
        gap: 0;
        margin-top: 48px;
        border-left: 3px solid var(--dorado);
        padding-left: 32px;
      }
      .historia-item { padding: 0 0 36px; position: relative; }
      .historia-item::before {
        content: '';
        position: absolute;
        left: -40px;
        top: 4px;
        width: 14px;
        height: 14px;
        background: var(--dorado);
        border-radius: 50%;
        border: 3px solid white;
        box-shadow: 0 0 0 2px var(--dorado);
      }
      .historia-year { font-size: 1.3rem; font-weight: 900; color: var(--azul); margin-bottom: 6px; }
      .historia-item p { font-size: 0.9rem; color: var(--gris-texto); line-height: 1.65; max-width: 540px; }

      /* CTA FINAL */
      .cta-final {
        background: linear-gradient(135deg, var(--azul), #0d2347);
        color: white;
        text-align: center;
        padding: 88px 24px;
      }
      .cta-final h2 { color: white; margin-bottom: 16px; }
      .cta-final p { opacity: 0.85; max-width: 520px; margin: 0 auto 36px; line-height: 1.7; }

      /* FOOTER */
      footer {
        background: #111;
        color: #777;
        text-align: center;
        padding: 28px 24px;
        font-size: 0.85rem;
        line-height: 1.8;
      }
      footer a { color: #aaa; }

      @media (max-width: 600px) {
        .stats { gap: 32px; }
        .stat-num { font-size: 2.2rem; }
      }
    </style>
  </head>
  <body>

    <!-- NAV -->
    <nav>
