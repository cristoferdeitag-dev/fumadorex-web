      * { margin: 0; padding: 0; box-sizing: border-box; }
      body { font-family: 'Inter', sans-serif; color: #1a1a1a; background: #fff; }
      
      /* HERO */
      .hero {
        background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
        color: white;
        padding: 80px 24px;
        text-align: center;
      }
      .hero .badge {
        display: inline-block;
        background: rgba(255,255,255,0.15);
        border: 1px solid rgba(255,255,255,0.3);
        padding: 6px 16px;
        border-radius: 999px;
        font-size: 13px;
        margin-bottom: 24px;
        letter-spacing: 0.05em;
      }
      .hero h1 {
        font-size: clamp(2rem, 5vw, 3.5rem);
        font-weight: 900;
        line-height: 1.15;
        max-width: 760px;
        margin: 0 auto 20px;
      }
      .hero h1 span { color: #f59e0b; }
      .hero p {
        font-size: 1.1rem;
        opacity: 0.85;
        max-width: 560px;
        margin: 0 auto 36px;
        line-height: 1.6;
      }
      .btn-primary {
        display: inline-block;
        background: #f59e0b;
        color: #1a1a1a;
        font-weight: 800;
        font-size: 1rem;
        padding: 16px 36px;
        border-radius: 8px;
        text-decoration: none;
        transition: transform 0.2s;
      }
      .btn-primary:hover { transform: scale(1.04); }

      /* STATS */
      .stats {
        background: #f8f8f8;
        padding: 48px 24px;
        display: flex;
        justify-content: center;
        gap: 48px;
        flex-wrap: wrap;
        text-align: center;
      }
      .stat-num { font-size: 2.5rem; font-weight: 900; color: #0f3460; }
      .stat-label { font-size: 0.9rem; color: #666; margin-top: 4px; }

      /* SECTION */
      section { padding: 72px 24px; max-width: 960px; margin: 0 auto; }
      h2 { font-size: clamp(1.6rem, 3vw, 2.4rem); font-weight: 800; margin-bottom: 16px; }
      h2 span { color: #0f3460; }

      /* CARDS */
      .cards {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 24px;
        margin-top: 40px;
      }
      .card {
        background: #f8f8f8;
        border-radius: 12px;
        padding: 28px 24px;
        border-left: 4px solid #f59e0b;
      }
      .card .icon { font-size: 2rem; margin-bottom: 12px; }
      .card h3 { font-size: 1rem; font-weight: 700; margin-bottom: 8px; }
      .card p { font-size: 0.9rem; color: #555; line-height: 1.6; }

      /* CTA FINAL */
      .cta-section {
        background: linear-gradient(135deg, #0f3460, #1a1a2e);
        color: white;
        text-align: center;
        padding: 80px 24px;
      }
      .cta-section h2 { color: white; margin-bottom: 16px; }
      .cta-section p { opacity: 0.85; max-width: 500px; margin: 0 auto 32px; line-height: 1.6; }

      /* FOOTER */
      footer {
        background: #111;
        color: #888;
        text-align: center;
        padding: 24px;
        font-size: 0.85rem;
      }
